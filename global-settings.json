{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*"
    ]
  },
  "model": "opus",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/silence-detector-ack.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/trust-flag-repair.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/dirty-main-warn.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/worktree-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/env-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/timestamp-injector.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/stale-worktree-warn.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/session-start-sync.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/post-merge-pull.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/skill-usage-tracker.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/claude-code-config/.claude/hooks/silence-detector.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
